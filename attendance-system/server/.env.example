PORT=4000
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/attendence
JWT_SECRET=put_long_random_secret
CORS_ORIGIN=http://localhost:5173
DEFAULT_RADIUS_METERS=100
MAX_ACCURACY_METERS=100
ALLOW_OUTSIDE_AS_FLAGGED=false
SERVE_WEB=false

# Local development uses src/uploads by default. On Vercel, Blob is automatic.
PHOTO_STORAGE=local
BLOB_ACCESS=private

# Only needed for local Blob testing. Vercel provides Blob credentials when the
# store is connected to the backend project.
BLOB_READ_WRITE_TOKEN=
